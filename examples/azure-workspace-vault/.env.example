# Copy to .env and fill in real values. Both keys are pushed into Azure Key
# Vault on first `vystak apply`; subsequent applies skip keys already in the
# vault unless --force is set. The running containers never see `.env` — they
# read secrets from Key Vault via ACA's secretRef mechanism.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
STRIPE_API_KEY=your-stripe-api-key-here
