# Copy to .env and fill in real values. .env is git-ignored.

# Required — Anthropic API access for the chatty agent and the haiku summarizer.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_API_URL=https://api.anthropic.com

# Optional — only needed if you want to test the Slack channel.
# Without these, the slack-main channel will fail to start; either set
# them or remove the slack-main channel block from vystak.yaml.
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-level-token-here
