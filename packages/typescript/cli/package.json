{
  "name": "vystak",
  "version": "0.0.1",
  "description": "Declarative, platform-agnostic orchestration for AI agents. Define once, deploy everywhere.",
  "type": "module",
  "license": "Apache-2.0",
  "homepage": "https://vystak.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/vystak/vystak.git",
    "directory": "packages/typescript/cli"
  },
  "keywords": [
    "ai",
    "agents",
    "orchestration",
    "langchain",
    "mastra",
    "deploy",
    "cli"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "vystak": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "fmt": "prettier --write src/ tests/"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "vitest": "^3.0.0"
  }
}
